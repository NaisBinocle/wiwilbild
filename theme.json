{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "primary",
					"color": "#FF99DA",
					"name": "Rose (Primary)"
				},
				{
					"slug": "primary-dark",
					"color": "#362C49",
					"name": "Violet foncé"
				},
				{
					"slug": "secondary",
					"color": "#7B74D0",
					"name": "Lavande"
				},
				{
					"slug": "foreground",
					"color": "#262626",
					"name": "Texte principal"
				},
				{
					"slug": "body",
					"color": "#737373",
					"name": "Texte courant"
				},
				{
					"slug": "muted",
					"color": "#A3A3A3",
					"name": "Texte discret"
				},
				{
					"slug": "border",
					"color": "#E5E5E5",
					"name": "Bordures"
				},
				{
					"slug": "surface",
					"color": "#FAFAFA",
					"name": "Fond de section"
				},
				{
					"slug": "background",
					"color": "#FFFFFF",
					"name": "Fond blanc"
				},
				{
					"slug": "success",
					"color": "#16A34A",
					"name": "Succès / Promo"
				},
				{
					"slug": "warning",
					"color": "#F59E0B",
					"name": "Étoiles / Alerte"
				},
				{
					"slug": "footer-bg",
					"color": "#241C34",
					"name": "Fond footer"
				}
			],
			"gradients": [
				{
					"slug": "hero",
					"gradient": "linear-gradient(153.3deg, #FFFFFF 0%, #FDFAFF 40%, #FFF0F8 100%)",
					"name": "Hero rose pâle"
				},
				{
					"slug": "primary-to-secondary",
					"gradient": "linear-gradient(135deg, #FF99DA 0%, #7B74D0 100%)",
					"name": "Rose → Lavande"
				}
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "'Playfair Display', serif",
					"slug": "heading",
					"name": "Playfair Display (Titres)",
					"fontFace": [
						{
							"fontFamily": "Playfair Display",
							"fontWeight": "800",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/PlayfairDisplay/PlayfairDisplay-ExtraBold.woff2"]
						},
						{
							"fontFamily": "Playfair Display",
							"fontWeight": "600",
							"fontStyle": "italic",
							"src": ["file:./assets/fonts/PlayfairDisplay/PlayfairDisplay-SemiBoldItalic-latin-ext.woff2"],
							"unicodeRange": "U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF"
						},
						{
							"fontFamily": "Playfair Display",
							"fontWeight": "600",
							"fontStyle": "italic",
							"src": ["file:./assets/fonts/PlayfairDisplay/PlayfairDisplay-SemiBoldItalic-latin.woff2"],
							"unicodeRange": "U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD"
						}
					]
				},
				{
					"fontFamily": "'Inter', sans-serif",
					"slug": "body",
					"name": "Inter (Corps)",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/Inter/Inter-Regular.woff2"]
						},
						{
							"fontFamily": "Inter",
							"fontWeight": "500",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/Inter/Inter-Medium.woff2"]
						},
						{
							"fontFamily": "Inter",
							"fontWeight": "600",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/Inter/Inter-SemiBold.woff2"]
						},
						{
							"fontFamily": "Inter",
							"fontWeight": "700",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/Inter/Inter-Bold.woff2"]
						},
						{
							"fontFamily": "Inter",
							"fontWeight": "800",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/Inter/Inter-ExtraBold.woff2"]
						},
						{
							"fontFamily": "Inter",
							"fontWeight": "900",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/Inter/Inter-Black.woff2"]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "2xs",  "size": "0.6875rem", "name": "11px (Badge)" },
				{ "slug": "xs",   "size": "0.75rem",   "name": "12px (Label)" },
				{ "slug": "sm",   "size": "0.875rem",  "name": "14px (Small)" },
				{ "slug": "base", "size": "1rem",       "name": "16px (Body)" },
				{ "slug": "md",   "size": "1.0625rem", "name": "17px (Body L)" },
				{ "slug": "lg",   "size": "1.125rem",  "name": "18px (Prix)" },
				{ "slug": "xl",   "size": "1.25rem",   "name": "20px" },
				{ "slug": "2xl",  "size": "1.75rem",   "name": "28px (Stat)" },
				{ "slug": "3xl",  "size": "2.5rem",    "name": "40px (H2)" },
				{ "slug": "4xl",  "size": "3.125rem",  "name": "50px (H1)" }
			]
		},
		"spacing": {
			"units": ["px", "rem", "%", "vw", "vh"],
			"spacingSizes": [
				{ "slug": "5",  "size": "4px",   "name": "4 (XXS)" },
				{ "slug": "10", "size": "8px",   "name": "8 (XS)" },
				{ "slug": "15", "size": "12px",  "name": "12 (S)" },
				{ "slug": "20", "size": "16px",  "name": "16 (Base)" },
				{ "slug": "25", "size": "20px",  "name": "20" },
				{ "slug": "30", "size": "24px",  "name": "24 (M)" },
				{ "slug": "40", "size": "32px",  "name": "32 (L)" },
				{ "slug": "50", "size": "48px",  "name": "48 (XL)" },
				{ "slug": "60", "size": "64px",  "name": "64 (2XL)" },
				{ "slug": "70", "size": "80px",  "name": "80 (3XL)" },
				{ "slug": "80", "size": "100px", "name": "100 (4XL)" }
			]
		},
		"layout": {
			"contentSize": "1280px",
			"wideSize": "1440px"
		},
		"custom": {
			"radius": {
				"card": "20px",
				"button": "12px",
				"badge": "6px",
				"pill": "100px",
				"sm": "4px"
			},
			"gap": {
				"product-grid": "24px",
				"testimonial-grid": "28px"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.6"
		},
		"spacing": {
			"padding": {
				"left": "var(--wp--preset--spacing--70)",
				"right": "var(--wp--preset--spacing--70)"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "800"
				},
				"color": {
					"text": "var(--wp--preset--color--primary-dark)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--4-xl)",
					"lineHeight": "1.1",
					"letterSpacing": "-1px"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--3-xl)",
					"lineHeight": "1.15",
					"letterSpacing": "-0.5px"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xl)",
					"lineHeight": "1.3"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--foreground)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--primary-dark)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--sm)"
				},
				"border": {
					"radius": "var(--wp--custom--radius--button)"
				},
				"spacing": {
					"padding": {
						"top": "14px",
						"bottom": "14px",
						"left": "24px",
						"right": "24px"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary-dark)",
						"text": "var(--wp--preset--color--background)"
					}
				}
			}
		},
		"blocks": {
			"core/button": {
				"border": {
					"radius": "var(--wp--custom--radius--button)"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "900",
					"fontSize": "1.75rem",
					"letterSpacing": "-1px"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "blank",
			"title": "Page vide (sans header/footer)",
			"postTypes": ["page"]
		}
	]
}
